{
  "manifest_version": 3,
  "name": "Aviso de sem Retorno Zendesk",
  "version": "1.0",
  "description": "Alerta após 4 minutos e meio de inatividade do cliente no Zendesk ",
  "permissions": ["storage", "notifications"],
  "content_scripts": [
    {
      "matches": ["https://*.zendesk.com/agent/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Aviso de sem Retorno Zendesk"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
